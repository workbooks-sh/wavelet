#!/usr/bin/env bash
# PATH shim around the real `wavelet` binary. Logs every invocation to
# $WAVELET_TRACE as one JSONL record per call, then forwards the call
# transparently.
#
# Required env (set by workbench wavelet.commercial action):
#   WAVELET_REAL    — absolute path to the real `wavelet` binary
#   WAVELET_TRACE   — absolute path to the trace file (jsonl, appended)
#
# Backend keys: Claude Code's Bash tool strips API-key-looking env vars
# (GOOGLE_API_KEY, FAL_KEY, ELEVENLABS_API_KEY, etc.) before spawning
# the shell that invokes this shim, so the agent's wavelet calls would
# otherwise see no credentials. We re-source them from
# ~/.config/wavelet/env here; the env file is the canonical source.
# Shell-exported values (if any survive sanitization) win over file
# values.

set -u

if [[ -z "${WAVELET_REAL:-}" ]]; then
  echo "wavelet-traced: WAVELET_REAL not set" >&2
  exit 127
fi
if [[ -z "${WAVELET_TRACE:-}" ]]; then
  echo "wavelet-traced: WAVELET_TRACE not set" >&2
  exit 127
fi

# Re-source backend keys claude-code's Bash sanitization stripped.
WAVELET_ENV_FILE="${HOME}/.config/wavelet/env"
if [[ -f "$WAVELET_ENV_FILE" ]]; then
  while IFS= read -r line || [[ -n "$line" ]]; do
    [[ -z "$line" || "$line" == \#* ]] && continue
    key="${line%%=*}"
    value="${line#*=}"
    [[ -z "$key" || "$key" == "$line" ]] && continue
    if [[ -z "${!key:-}" ]]; then
      export "$key=$value"
    fi
  done < "$WAVELET_ENV_FILE"
fi

# Force HTML-first composition path during eval runs. The legacy
# `wavelet render comp.json` path bypasses the lint coverage we wire
# into commercial.html (post-render --mp4 halo contrast, the lint
# rules that walk scene HTML). Setting WAVELET_STRICT_HTML=1 makes
# `wavelet render` reject comp.json outright — the agent gets a clear
# error and is forced to write the canonical manifest. See render.rs
# for the gate.
export WAVELET_STRICT_HTML=1

# ORT (ONNX Runtime) for the depth + OCR features. The ort crate built
# with `load-dynamic` defers loading libonnxruntime.dylib to runtime
# and reads this env var to locate it. macOS path via Homebrew bottle:
if [[ -z "${ORT_DYLIB_PATH:-}" && -f /opt/homebrew/lib/libonnxruntime.dylib ]]; then
  export ORT_DYLIB_PATH=/opt/homebrew/lib/libonnxruntime.dylib
fi

ts_start=$(date -u +%Y-%m-%dT%H:%M:%SZ)
ms_start=$(/usr/bin/python3 -c 'import time; print(int(time.time()*1000))')

stdout_tmp=$(mktemp)
stderr_tmp=$(mktemp)
trap 'rm -f "$stdout_tmp" "$stderr_tmp"' EXIT

"$WAVELET_REAL" "$@" > >(tee "$stdout_tmp") 2> >(tee "$stderr_tmp" >&2)
exit_code=$?

ms_end=$(/usr/bin/python3 -c 'import time; print(int(time.time()*1000))')
duration_ms=$(( ms_end - ms_start ))
stdout_bytes=$(wc -c < "$stdout_tmp" | tr -d ' ')
stderr_bytes=$(wc -c < "$stderr_tmp" | tr -d ' ')

# Build JSON via python so argv quoting is correct without bash gymnastics.
/usr/bin/python3 - "$ts_start" "$duration_ms" "$exit_code" "$stdout_bytes" "$stderr_bytes" "$@" <<'PY' >> "$WAVELET_TRACE"
import json, sys
ts, dur, exit_code, sob, seb, *argv = sys.argv[1:]
print(json.dumps({
    "ts": ts,
    "argv": ["wavelet", *argv],
    "duration_ms": int(dur),
    "exit": int(exit_code),
    "stdout_bytes": int(sob),
    "stderr_bytes": int(seb),
}, separators=(",", ":")))
PY

exit "$exit_code"
